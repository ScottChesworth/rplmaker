{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rplMaker",
  "version": "0.1.0",
  "identifier": "dev.scottchesworth.rplmaker",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "rplMaker",
        "width": 760,
        "height": 680,
        "minWidth": 480,
        "minHeight": 420
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
